#!/usr/bin/env bash
# tx-lattice — resolve a batch of Conway transactions and their inputs
# into Turtle files (one per tx), ready for SPARQL.
#
# Usage:
#   tx-lattice --rules rules.yaml --out-dir DIR [--network mainnet|preprod|preview] \
#              <txId1> <txId2> ... <txIdN>
#
# Env:
#   BLOCKFROST_PROJECT_ID  required
#   TX_GRAPH_EXE           override path to tx-graph binary
#                          (default: tx-graph on PATH, else result/bin/tx-graph)
#
# For each <txId> the script writes  DIR/<txid>.ttl  containing:
#   - tx-graph's body emit of the tx (rules overlay applied)
#   - resolved-input bridge blocks: every input gets a
#     `_:resolved_input<N>` carrying the parent's address+lovelace,
#     bridged from `_:input<N>` via `cardano:resolvedTo`.
#
# Inputs are resolved via Blockfrost's /txs/<hash>/utxos endpoint —
# inputs come back already resolved (parent address + amount + datum)
# in one API call per tx.
#
# Once produced, query across all txs with:
#   nix-shell -p apache-jena --run \
#     "sparql $(printf -- '--data %s ' DIR/*.ttl) --query foo.rq"
#
# Or project a single tx with the packaged views:
#   tx-view --graph DIR/<txid>.ttl --view cli-tree

set -euo pipefail

NETWORK="mainnet"
RULES=""
OUT_DIR=""
TXIDS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --rules)   RULES="$2"; shift 2 ;;
    --out-dir) OUT_DIR="$2"; shift 2 ;;
    --network) NETWORK="$2"; shift 2 ;;
    --help|-h)
      sed -n '2,/^$/p' "$0" | sed 's/^# \?//'
      exit 0 ;;
    -*) echo "tx-lattice: unknown flag $1" >&2; exit 2 ;;
    *)  TXIDS+=("$1"); shift ;;
  esac
done

[[ -n "$RULES" ]] || { echo "tx-lattice: --rules required" >&2; exit 2; }
[[ -n "$OUT_DIR" ]] || { echo "tx-lattice: --out-dir required" >&2; exit 2; }
[[ ${#TXIDS[@]} -gt 0 ]] || { echo "tx-lattice: pass at least one txId" >&2; exit 2; }
[[ -n "${BLOCKFROST_PROJECT_ID:-}" ]] || {
  echo "tx-lattice: BLOCKFROST_PROJECT_ID env required" >&2; exit 2; }

if [[ -n "${TX_GRAPH_EXE:-}" ]]; then
  TXG="$TX_GRAPH_EXE"
elif command -v tx-graph >/dev/null 2>&1; then
  TXG="$(command -v tx-graph)"
elif [[ -x "result/bin/tx-graph" ]]; then
  TXG="result/bin/tx-graph"
else
  echo "tx-lattice: tx-graph not found — set TX_GRAPH_EXE, put tx-graph on PATH, or run 'nix build .#tx-graph' first" >&2
  exit 2
fi

case "$NETWORK" in
  mainnet) BASE_URL="https://cardano-mainnet.blockfrost.io/api/v0" ;;
  preprod) BASE_URL="https://cardano-preprod.blockfrost.io/api/v0" ;;
  preview) BASE_URL="https://cardano-preview.blockfrost.io/api/v0" ;;
  *) echo "tx-lattice: unknown network $NETWORK" >&2; exit 2 ;;
esac

mkdir -p "$OUT_DIR"
WORK=$(mktemp -d /tmp/tx-lattice.XXXXXX)
trap 'rm -rf "$WORK"' EXIT

bf() { curl -fsS -H "project_id: $BLOCKFROST_PROJECT_ID" "$BASE_URL$1"; }

emit_one() {
  local txid="$1"
  local out="$OUT_DIR/$txid.ttl"
  local stage="$WORK/$txid"
  mkdir -p "$stage"

  echo "tx-lattice: $txid" >&2

  bf "/txs/$txid/cbor" | jq -r '.cbor' | xxd -r -p > "$stage/tx.cbor"
  "$TXG" --rules "$RULES" --tx "$stage/tx.cbor" > "$stage/body.ttl"

  bf "/txs/$txid/utxos" > "$stage/utxos.json"

  {
    awk 'NR==1{flag=1} /^@prefix/{print; next} flag{print}' "$stage/body.ttl"
    echo ""
    echo "#"
    echo "# Resolved inputs (depth 1) for tx $txid"
    echo "# Source: Blockfrost $BASE_URL/txs/$txid/utxos"
    echo "#"
    jq -r --arg txid "$txid" '
      .inputs | to_entries[] |
      {
        n: (.key + 1),
        txid: .value.tx_hash,
        ix: .value.output_index,
        addr: .value.address,
        lovelace: (
          [.value.amount[] | select(.unit == "lovelace") | .quantity | tonumber]
          | first // 0
        ),
        reference: (.value.reference // false),
        collateral: (.value.collateral // false)
      } |
      "_:resolved_input\(.n) a cardano:Output ;\n" +
      "  cardano:atAddress [ a cardano:Address ; cardano:bech32 \"\(.addr)\" ] ;\n" +
      "  cardano:lovelace \(.lovelace) ;\n" +
      "  cardano:fromParentTxId \"\(.txid)\" ;\n" +
      "  cardano:fromParentIndex \(.ix) ;\n" +
      "  cardano:isReferenceInput \(.reference) ;\n" +
      "  cardano:isCollateralInput \(.collateral) .\n" +
      "\n_:input\(.n) cardano:resolvedTo _:resolved_input\(.n) .\n"
    ' "$stage/utxos.json"
  } > "$out"

  echo "tx-lattice:   → $out ($(wc -l < "$out") lines)" >&2
}

for txid in "${TXIDS[@]}"; do
  emit_one "$txid"
done

echo "tx-lattice: done. ${#TXIDS[@]} tx(s) → $OUT_DIR/" >&2
