#!/usr/bin/env bash
# tx-lattice — fetch a *closure* of Conway transactions and emit one
# canonical Turtle file per tx.
#
# Architecture:
#
#   The only Blockfrost endpoint used is /txs/<hash>/cbor.  Every input
#   in a Conway tx references its parent UTxO by (txid, ix); tx-graph
#   already emits those references as `cardano:fromTxOutRef →
#   cardano:hasTxId _:hash_txid_<HEX>`.  This script walks those
#   references, fetches each parent's CBOR, emits it as its own
#   canonical Turtle file, and recurses up to --depth.  The on-disk
#   bundle is then a real lattice: a SPARQL query that joins an input
#   in tx A with the matching output of tx B finds both sides in the
#   default graph, with full tx-graph fidelity (multi-asset values,
#   datums, redeemers — everything tx-graph emits on outputs).
#
#   No /utxos call, no hand-built "resolved input" bridge: the parent
#   tx's outputs ARE the resolved inputs.
#
# Usage:
#   tx-lattice --rules rules.yaml --out-dir DIR \
#              [--network mainnet|preprod|preview] [--depth N] \
#              <txId1> <txId2> ... <txIdN>
#
# Env:
#   BLOCKFROST_PROJECT_ID  required
#   TX_GRAPH_EXE           override path to tx-graph binary
#                          (default: tx-graph on PATH, else result/bin/tx-graph)
#
# For each tx in the closure the script writes  DIR/<txid>.ttl
# (created via tx-graph) plus a trailing `_:tx cardano:hasTxId "<hex>"`
# triple so SPARQL can identify each tx by its on-chain hash.
#
# Then query across the whole closure with:
#   nix-shell -p apache-jena --run \
#     "sparql $(printf -- '--data %s ' DIR/*.ttl) --query foo.rq"
#
# Or project a single tx with the packaged views:
#   tx-view --graph DIR/<txid>.ttl --view cli-tree

set -euo pipefail

NETWORK="mainnet"
RULES=""
OUT_DIR=""
DEPTH=1
TXIDS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --rules)   RULES="$2"; shift 2 ;;
    --out-dir) OUT_DIR="$2"; shift 2 ;;
    --network) NETWORK="$2"; shift 2 ;;
    --depth)   DEPTH="$2"; shift 2 ;;
    --help|-h)
      sed -n '2,/^$/p' "$0" | sed 's/^# \?//'
      exit 0 ;;
    -*) echo "tx-lattice: unknown flag $1" >&2; exit 2 ;;
    *)  TXIDS+=("$1"); shift ;;
  esac
done

[[ -n "$RULES" ]] || { echo "tx-lattice: --rules required" >&2; exit 2; }
[[ -n "$OUT_DIR" ]] || { echo "tx-lattice: --out-dir required" >&2; exit 2; }
[[ ${#TXIDS[@]} -gt 0 ]] || { echo "tx-lattice: pass at least one txId" >&2; exit 2; }
[[ -n "${BLOCKFROST_PROJECT_ID:-}" ]] || {
  echo "tx-lattice: BLOCKFROST_PROJECT_ID env required" >&2; exit 2; }

if [[ -n "${TX_GRAPH_EXE:-}" ]]; then
  TXG="$TX_GRAPH_EXE"
elif command -v tx-graph >/dev/null 2>&1; then
  TXG="$(command -v tx-graph)"
elif [[ -x "result/bin/tx-graph" ]]; then
  TXG="result/bin/tx-graph"
else
  echo "tx-lattice: tx-graph not found — set TX_GRAPH_EXE, put tx-graph on PATH, or run 'nix build .#tx-graph' first" >&2
  exit 2
fi

case "$NETWORK" in
  mainnet) BASE_URL="https://cardano-mainnet.blockfrost.io/api/v0" ;;
  preprod) BASE_URL="https://cardano-preprod.blockfrost.io/api/v0" ;;
  preview) BASE_URL="https://cardano-preview.blockfrost.io/api/v0" ;;
  *) echo "tx-lattice: unknown network $NETWORK" >&2; exit 2 ;;
esac

mkdir -p "$OUT_DIR"
# Each tx's CBOR is also kept on disk under <OUT_DIR>/cbor/<txid>.cbor
# so tx-graph --closure-dir can resolve a seed tx's inputs in-process
# against parent CBORs at body-emit time. Issue #112 (fixes #102):
# without this, the typed-redeemer dispatch in tx-graph's Witness
# walker falls back to NoBlueprintRegistered for every spending
# redeemer (the lookup is keyed by the spending input's parent
# script-hash, which the empty default ResolvedUTxO cannot provide).
CBOR_DIR="$OUT_DIR/cbor"
mkdir -p "$CBOR_DIR"

WORK=$(mktemp -d /tmp/tx-lattice.XXXXXX)
trap 'rm -rf "$WORK"' EXIT

bf_cbor() {
  curl -fsS -H "project_id: $BLOCKFROST_PROJECT_ID" \
    "$BASE_URL/txs/$1/cbor"
}

# Fetch a tx's CBOR into the closure dir if not already present.
# Also dumps a quick scratch TTL into a temp file so the BFS step
# can read out the parent txids without committing to the final
# emit (which needs --closure-dir populated and therefore can't
# run until the BFS finishes).
fetch_cbor() {
  local txid="$1"
  local cbor_persistent="$CBOR_DIR/$txid.cbor"
  if [[ ! -f "$cbor_persistent" ]]; then
    echo "tx-lattice: fetch $txid" >&2
    bf_cbor "$txid" | jq -r '.cbor' | xxd -r -p > "$cbor_persistent"
  fi
}

# Run tx-graph against a CBOR with no closure-dir, just to extract
# the input/reference-input/collateral parent txids it references
# (encoded as `_:hash_txid_<HEX>` bnode labels in the emit).
scratch_parents() {
  local txid="$1"
  local cbor_persistent="$CBOR_DIR/$txid.cbor"
  "$TXG" --rules "$RULES" --tx "$cbor_persistent" 2>/dev/null \
    | grep -oE '_:hash_txid_[a-f0-9]+' \
    | sed 's/^_:hash_txid_//' \
    | sort -u
}

# Final emit. Seeds run with --closure-dir so spending-redeemer
# typed decode fires (issue #112); parents are emitted without
# it (no need to dispatch their own redeemers).
emit_final() {
  local txid="$1"
  local role="$2"
  local out="$OUT_DIR/$txid.ttl"
  local cbor_persistent="$CBOR_DIR/$txid.cbor"
  echo "tx-lattice: emit ($role) $txid" >&2
  if [[ "$role" == "seed" ]]; then
    "$TXG" --rules "$RULES" --tx "$cbor_persistent" \
      --closure-dir "$CBOR_DIR" > "$out"
  else
    "$TXG" --rules "$RULES" --tx "$cbor_persistent" > "$out"
  fi
  # tx-graph already emits the tx's own `cardano:hasTxId` triple
  # and the per-output `cardano:hasIndex` triples natively (issue
  # #100). All tx-lattice has to add on top is the lattice-role
  # marker:
  #   "seed"   — the user's input set; consumption originating
  #              here is "happened during the lattice's time window"
  #   "parent" — closure-pulled ancestor; its outputs are joined
  #              to as resolution targets of seed inputs
  printf '\n_:tx cardano:hasLatticeRole "%s" .\n' "$role" >> "$out"
}

# Two-pass closure walk. Issue #112: a seed's spending-redeemer
# decode needs --closure-dir populated with PARENT CBORs at emit
# time, so the BFS first fetches every CBOR into $CBOR_DIR, then
# a second pass emits the TTLs with --closure-dir for seeds.
#
# BFS state. Three parallel lists (txid, depth, role) form the
# queue. Seeds enter at depth 0 with role="seed"; their direct
# parents enter at depth 1 with role="parent"; deeper layers
# all keep role="parent". A flat `seen_order[@]` records the
# emit order so we can replay it in pass 2 without re-walking.
declare -A seen
declare -A role_of
seen_order=()
queue=()
queue_depth=()
queue_role=()
for t in "${TXIDS[@]}"; do
  queue+=("$t")
  queue_depth+=("0")
  queue_role+=("seed")
done

# Pass 1: BFS, fetch every CBOR + record emit order.
while [[ ${#queue[@]} -gt 0 ]]; do
  txid="${queue[0]}"
  depth="${queue_depth[0]}"
  role="${queue_role[0]}"
  queue=("${queue[@]:1}")
  queue_depth=("${queue_depth[@]:1}")
  queue_role=("${queue_role[@]:1}")

  if [[ -n "${seen[$txid]:-}" ]]; then
    continue
  fi
  seen[$txid]=1
  role_of[$txid]="$role"
  seen_order+=("$txid")

  fetch_cbor "$txid"

  if (( depth < DEPTH )); then
    next_depth=$((depth + 1))
    while IFS= read -r parent; do
      if [[ -n "$parent" && -z "${seen[$parent]:-}" ]]; then
        queue+=("$parent")
        queue_depth+=("$next_depth")
        queue_role+=("parent")
      fi
    done < <(scratch_parents "$txid")
  fi
done

# Pass 2: emit TTL for every fetched tx with closure-dir fully
# populated.
emitted=0
for txid in "${seen_order[@]}"; do
  emit_final "$txid" "${role_of[$txid]}"
  emitted=$((emitted + 1))
done

echo "tx-lattice: done. $emitted tx(s) in closure (depth=$DEPTH) → $OUT_DIR/" >&2
