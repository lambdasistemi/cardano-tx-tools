#!/usr/bin/env bash
# tx-lattice — thin convenience wrapper around tx-fetch + tx-graph.
#
# Architecture (post-#114 + post-tx-fetch split):
#
#   tx-fetch  fetches the closure of CBORs into <out-dir>/cbor/.
#   tx-graph  --in-dir <out-dir>/cbor --out-dir <out-dir> indexes every
#             CBOR by its computed TxId and emits one canonical Turtle
#             file per tx, with the operator overlay merged in if
#             --rules is supplied.
#
#   This wrapper composes the two for the operator's convenience.  For
#   raw closure fetches (no overlay, no rules), use tx-fetch directly.
#   For one-tx-at-a-time emit, use tx-graph directly.
#
# Usage:
#   tx-lattice [--rules rules.yaml] --out-dir DIR \
#              [--network mainnet|preprod|preview] [--depth N] \
#              <txId1> <txId2> ... <txIdN>
#
# Env:
#   BLOCKFROST_PROJECT_ID  required (for tx-fetch)
#   TX_GRAPH_EXE           override path to tx-graph binary
#                          (default: tx-graph on PATH, else result/bin/tx-graph)
#   TX_FETCH_EXE           override path to tx-fetch binary
#                          (default: tx-fetch on PATH, else result/bin/tx-fetch)

set -euo pipefail

NETWORK="mainnet"
RULES=""
OUT_DIR=""
DEPTH=1
TXIDS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --rules)   RULES="$2"; shift 2 ;;
    --out-dir) OUT_DIR="$2"; shift 2 ;;
    --network) NETWORK="$2"; shift 2 ;;
    --depth)   DEPTH="$2"; shift 2 ;;
    --help|-h)
      sed -n '2,/^$/p' "$0" | sed 's/^# \?//'
      exit 0 ;;
    -*) echo "tx-lattice: unknown flag $1" >&2; exit 2 ;;
    *)  TXIDS+=("$1"); shift ;;
  esac
done

[[ -n "$OUT_DIR" ]] || { echo "tx-lattice: --out-dir required" >&2; exit 2; }
[[ ${#TXIDS[@]} -gt 0 ]] || { echo "tx-lattice: pass at least one txId" >&2; exit 2; }

if [[ -n "${TX_FETCH_EXE:-}" ]]; then
  TXF="$TX_FETCH_EXE"
elif command -v tx-fetch >/dev/null 2>&1; then
  TXF="$(command -v tx-fetch)"
elif [[ -x "result/bin/tx-fetch" ]]; then
  TXF="result/bin/tx-fetch"
else
  echo "tx-lattice: tx-fetch not found — set TX_FETCH_EXE, put tx-fetch on PATH, or run 'nix build .#tx-fetch' first" >&2
  exit 2
fi

if [[ -n "${TX_GRAPH_EXE:-}" ]]; then
  TXG="$TX_GRAPH_EXE"
elif command -v tx-graph >/dev/null 2>&1; then
  TXG="$(command -v tx-graph)"
elif [[ -x "result/bin/tx-graph" ]]; then
  TXG="result/bin/tx-graph"
else
  echo "tx-lattice: tx-graph not found — set TX_GRAPH_EXE, put tx-graph on PATH, or run 'nix build .#tx-graph' first" >&2
  exit 2
fi

"$TXF" --out-dir "$OUT_DIR" --network "$NETWORK" --depth "$DEPTH" "${TXIDS[@]}"

if [[ -n "$RULES" ]]; then
  "$TXG" --rules "$RULES" --in-dir "$OUT_DIR/cbor" --out-dir "$OUT_DIR"
else
  "$TXG" --in-dir "$OUT_DIR/cbor" --out-dir "$OUT_DIR"
fi

emitted=$(find "$OUT_DIR" -maxdepth 1 -name '*.ttl' | wc -l)
echo "tx-lattice: done. $emitted ttl(s) in closure (depth=$DEPTH) → $OUT_DIR/" >&2
