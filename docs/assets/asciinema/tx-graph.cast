[21.186381, "o", "  cardano:lovelace 1500000 ;\r\n  cardano:hasDatum _:outputDatum1 ;\r\n  cardano:hasReferenceScript _:outputRefScript1 .\r\n\r\n_:outputDatum1 a cardano:Datum ;\r\n  cardano:hasHash _:hash_datum_9e1199a988ba72ff ;\r\n  cardano:hasRawBytes \"182a\" .\r\n--\r\n\r\n_:outputRefScript1 a cardano:NativeScript ;\r\n  cardano:hasHash _:hash_script_5334c8c55ec6518f ;\r\n  cardano:hasRawBytes \"8200581c11111111111111111111111111111111111111111111111111111111\" .\r\n\r\n_:hash_script_5334c8c55ec6518f a cardano:Identifier ;\r\n  cardano:leafType \"ScriptHash\" ;\r\n"]
