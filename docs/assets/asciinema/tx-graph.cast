[15.289065, "o", "# Output 1\r\n#\r\n\r\n_:output1 a cardano:Output ;\r\n  cardano:atAddress _:amaru_swap_orderAddr ;\r\n  cardano:lovelace 39306821250 ;\r\n  cardano:hasDatum _:outputDatum1 .\r\n\r\n_:outputDatum1 a cardano:Datum ;\r\n  cardano:hasHash _:hash_datum_26e52c102635ef40 ;\r\n  cardano:hasRawBytes \"\" .\r\n\r\n_:hash_datum_26e52c102635ef40 a cardano:Identifier ;\r\n  cardano:leafType \"DatumHash\" ;\r\n  cardano:bytesHex \"26e52c102635ef40593de00677d74fcc10d601cc6a30803475b2a1761ec75b93\" .\r\n\r\n#\r\n# Output 2\r\n#\r\n\r\n_:output2 a cardano:Output ;\r\n  cardano:atAddress _:amaru_swap_orderAddr ;\r\n  cardano:lovelace 39306821249 ;\r\n  cardano:hasDatum _:outputDatum2 .\r\n\r\n_:outputDatum2 a cardano:Datum ;\r\n  cardano:hasHash _:hash_datum_db9408d0ef15766f ;\r\n  cardano:hasRawBytes \"\" .\r\n\r\n_:hash_datum_db9408d0ef15766f a cardano:Identifier ;\r\n  cardano:leafType \"DatumHash\" ;\r\n  cardano:bytesHex \"db9408d0ef15766fe0e28b1dc9a384efb93e862ca2ece35edc37cd3791c4b54c\" .\r\n"]
[20.29163, "o", "\u001b[1;32m$\u001b[0m # Section 4 — address decomposition preserves entity-named credentials.\r\n"]
[20.69424, "o", "\u001b[1;32m$\u001b[0m grep -A4 \"a cardano:Address\" graph.ttl | head -24\r\n"]
[21.099441, "o", "_:amaru_swap_orderAddr a cardano:Address ;\r\n  cardano:bech32 \"addr1x8ax5k9mutg07p2ngscu3chsauktmstq92z9de938j8nqaejyqwur6p8pqmycmzz55lcnan4x99mnt2a5fe54ggt4gxst7gy3n\" ;\r\n  cardano:hasPaymentCredential _:amaru_swap_orderCredPayment ;\r\n  cardano:hasStakeCredential _:amaru_swap_orderCredStake .\r\n\r\n--\r\n_:amaru_treasury_network_complianceAddr a cardano:Address ;\r\n  cardano:bech32 \"addr1xyezq8wpaqnssdjvd3p220uf7e6nzjae44w6yu625y965rfjyqwur6p8pqmycmzz55lcnan4x99mnt2a5fe54ggt4gxs8thzgk\" ;\r\n  cardano:hasPaymentCredential _:amaru_treasury_network_complianceCredPayment ;\r\n  cardano:hasStakeCredential _:amaru_treasury_network_complianceCredStake .\r\n\r\n--\r\n_:amaru_network_walletAddr a cardano:Address ;\r\n  cardano:bech32 \"addr1qx9aqvsf6gne2640jec828s25gzhk5wp2day8u24kf8mrs2v0zyuvk80fay35dx008p45ts0u6cdrv9g2maetq8jm8psznjcrz\" ;\r\n  cardano:hasPaymentCredential _:amaru_network_walletCredPayment ;\r\n  cardano:hasStakeCredential _:amaru_network_walletCredStake .\r\n\r\n"]
[26.103028, "o", "\u001b[1;32m$\u001b[0m # Section 5 — withdrawals, collateral return, redeemers, and execution units.\r\n"]
