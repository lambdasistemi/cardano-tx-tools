{"version": 2, "width": 138, "height": 24, "timestamp": 1779438618, "env": {"SHELL": "/nix/store/rlq03x4cwf8zn73hxaxnx0zn5q9kifls-bash-5.3p3/bin/bash", "TERM": "xterm-256color"}}
[0.013111, "o", "\u001b[H\u001b[J\u001b[3J\u001b[1;32m$\u001b[0m tx-graph --help\r\n"]
[0.423485, "o", "tx-graph — operator-entity overlay + body emitter\r\n\r\nUsage: tx-graph [--rules FILE] [--tx PATH | -] [--utxo FILE] \r\n                [--n2c-socket-path SOCKET] [--network-magic WORD32] [--out FILE]\r\n                [--format FORMAT]\r\n\r\n  tx-graph — operator-entity overlay + body emitter. Loads operator-authored\r\n  rules (overlay-only mode) or drives the joint-graph body emitter on a Conway\r\n  tx + resolved UTxO. Output format defaults to Turtle.\r\n\r\nAvailable options:\r\n  --rules FILE             Operator-authored rules file (.yaml/.yml or .ttl).\r\n"]
[0.423715, "o", "                           Overlay-only mode when used alone.\r\n  --tx PATH | -            Conway tx CBOR (hex text envelope, raw hex, or\r\n                           binary). '-' reads from stdin. Triggers the\r\n                           body-emitting dispatcher.\r\n  --utxo FILE              Resolved-UTxO JSON for the tx's inputs. Mutually\r\n                           exclusive with --n2c-socket-path.\r\n  --n2c-socket-path SOCKET Local cardano-node Node-to-Client socket. When\r\n                           supplied, the tx's inputs are resolved live against\r\n                           the node (requires --network-magic).\r\n  --network-magic WORD32   Network magic for the --n2c-socket-path session.\r\n                           Defaults to mainnet. (default: 764824073)\r\n  --out FILE               Output destination (default: stdout).\r\n  --format FORMAT          Output format: 'turtle' or 'json-ld'.\r\n                           (default: \"turtle\")\r\n  -h,--help                Show this help text\r\n"]
[3.42878, "o", "\u001b[1;32m$\u001b[0m # Section 1 — fixture 11 rules: operator-declared entities.\r\n"]
[3.831543, "o", "\u001b[1;32m$\u001b[0m tx-graph --rules .../11-amaru-treasury-swap-real/rules.yaml | head -24\r\n"]
[4.241698, "o", "@prefix cardano: <https://lambdasistemi.github.io/cardano-knowledge-maps/vocab/cardano#> .\r\n@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .\r\n@prefix :        <https://lambdasistemi.github.io/cardano-tx-tools/fixtures/11-amaru-treasury-swap-real#> .\r\n\r\n#\r\n# Operator-declared entities (from rules.yaml).\r\n#\r\n\r\n:amaru_treasury_network_compliance a cardano:Entity ;\r\n  rdfs:label \"amaru-treasury.network_compliance\" ;\r\n  cardano:hasIdentifier _:amaru_treasury_network_compliance_paymentScript ;\r\n  cardano:hasIdentifier _:amaru_treasury_network_compliance_stakeScript .\r\n\r\n_:amaru_treasury_network_compliance_paymentScript a cardano:Identifier ;\r\n  cardano:leafType \"PaymentScript\" ;\r\n  cardano:bytesHex \"32201dc1e82708364c6c42a53f89f675314bb9ad5da2734aa10baa0d\" .\r\n\r\n_:amaru_treasury_network_compliance_stakeScript a cardano:Identifier ;\r\n  cardano:leafType \"StakeScript\" ;\r\n  cardano:bytesHex \"32201dc1e82708364c6c42a53f89f675314bb9ad5da2734aa10baa0d\" .\r\n\r\n:amaru_swap_order a cardano:Entity ;\r\n  rdfs:label \"amaru.swap-order\" ;\r\n  cardano:hasIdentifier _:amaru_swap_order_paymentScript ;\r\n"]
[8.246983, "o", "\u001b[1;32m$\u001b[0m # Section 2 — fixture 11 real tx: rules + CBOR produce one joint RDF graph.\r\n"]
[8.650984, "o", "\u001b[1;32m$\u001b[0m tx-graph --rules .../11-amaru-treasury-swap-real/rules.yaml --tx .../5fc04113....cbor.hex\r\n"]
[9.071074, "o", "\u001b[1;32m$\u001b[0m sed -n \"55,82p\" graph.ttl\r\n"]
[9.476638, "o", "  cardano:hasInput _:input2 ;\r\n  cardano:hasReferenceInput _:refInput1 ;\r\n  cardano:hasReferenceInput _:refInput2 ;\r\n  cardano:hasReferenceInput _:refInput3 ;\r\n  cardano:hasReferenceInput _:refInput4 ;\r\n  cardano:hasOutput _:output1 ;\r\n  cardano:hasOutput _:output2 ;\r\n  cardano:hasOutput _:output3 ;\r\n  cardano:hasOutput _:output4 ;\r\n  cardano:hasWithdrawal _:withdrawal1 ;\r\n  cardano:hasCollateralInput _:collateral1 ;\r\n  cardano:hasFee 452865 ;\r\n  cardano:hasValidityInterval _:interval1 ;\r\n  cardano:scriptDataHash _:hash_scriptdata_5cc5c166e6c13b9f ;\r\n  cardano:auxiliaryDataHash _:hash_auxiliarydata_a13ae6381df9332e ;\r\n  cardano:hasRequiredSigner _:amaru_network_wallet_paymentKey ;\r\n  cardano:hasRequiredSigner _:cred_paymentkey_f3ab64b0f97dcf0f ;\r\n  cardano:totalCollateral 679298 ;\r\n  cardano:hasCollateralReturn _:collateralReturn1 ;\r\n  cardano:hasRedeemer _:redeemer1 ;\r\n  cardano:hasRedeemer _:redeemer2 ;\r\n  cardano:hasKeyWitness _:keyWitness1 ;\r\n  cardano:hasKeyWitness _:keyWitness2 .\r\n\r\n_:interval1 cardano:intervalEnd 187660799 .\r\n\r\n_:hash_scriptdata_5cc5c166e6c13b9f a cardano:Identifier ;\r\n  cardano:leafType \"ScriptDataHash\" ;\r\n"]
[14.479806, "o", "\u001b[1;32m$\u001b[0m # Section 3 — real outputs: lovelace amounts plus inline datum blocks.\r\n"]
