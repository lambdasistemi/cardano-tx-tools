[32.832992, "o", "@prefix cardano: <https://lambdasistemi.github.io/cardano-knowledge-maps/vocab/cardano#> .\r\n@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .\r\n@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .\r\n@prefix :        <https://lambdasistemi.github.io/cardano-tx-tools/fixtures/tx#> .\r\n\r\n#\r\n# Transaction body.\r\n#\r\n\r\n_:tx a cardano:Transaction ;\r\n  cardano:hasInput _:input1 ;\r\n  cardano:hasInput _:input2 ;\r\n  cardano:hasReferenceInput _:refInput1 ;\r\n  cardano:hasReferenceInput _:refInput2 ;\r\n  cardano:hasReferenceInput _:refInput3 ;\r\n  cardano:hasReferenceInput _:refInput4 ;\r\n  cardano:hasOutput _:output1 ;\r\n  cardano:hasOutput _:output2 ;\r\n  cardano:hasOutput _:output3 ;\r\n  cardano:hasWithdrawal _:withdrawal1 ;\r\n  cardano:hasCollateralInput _:collateral1 ;\r\n  cardano:hasFee 417509 ;\r\n  cardano:hasValidityInterval _:interval1 ;\r\n  cardano:scriptDataHash _:hash_scriptdata_891c4344a9d3fdf3 ;\r\n  cardano:auxiliaryDataHash _:hash_auxiliarydata_9e7ffa621fc80d1a ;\r\n"]
