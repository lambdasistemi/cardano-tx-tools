{"version": 2, "width": 100, "height": 35, "timestamp": 1779296222, "env": {"SHELL": "/nix/store/rlq03x4cwf8zn73hxaxnx0zn5q9kifls-bash-5.3p3/bin/bash", "TERM": "tmux-256color"}}
[0.010492, "o", "\u001b[H\u001b[J\u001b[3J"]
[0.010847, "o", "\u001b[1;32m$\u001b[0m tx-graph --help\r\n"]
[0.625519, "o", "tx-graph — operator-entity overlay + body emitter\r\n\r\nUsage: tx-graph [--rules FILE] [--tx PATH | -] [--utxo FILE] \r\n                [--n2c-socket-path SOCKET] [--network-magic WORD32] [--out FILE]\r\n                [--format FORMAT]\r\n\r\n  tx-graph — operator-entity overlay + body emitter. Loads operator-authored\r\n  rules (overlay-only mode) or drives the joint-graph body emitter on a Conway\r\n  tx + resolved UTxO. Output format defaults to Turtle.\r\n\r\nAvailable options:\r\n  --rules FILE             Operator-authored rules file (.yaml/.yml or .ttl).\r\n                           Overlay-only mode when used alone.\r\n  --tx PATH | -            Conway tx CBOR (hex text envelope, raw hex, or\r\n                           binary). '-' reads from stdin. Triggers the\r\n                           body-emitting dispatcher.\r\n  --utxo FILE              Resolved-UTxO JSON for the tx's inputs. Mutually\r\n                           exclusive with --n2c-socket-path.\r\n  --n2c-socket-path SOCKET Local cardano-node Node-to-Client socket. When\r\n                           supplied, the tx's inputs are resolved live against\r\n                           the node (requires --network-magic).\r\n  --network-magic WORD32   Network magic for the --n2c-socket-path session.\r\n                           Defaults to mainnet. (default: 764824073)\r\n  --out FILE               Output destination (default: stdout).\r\n  --format FORMAT          Output format: 'turtle' or 'json-ld'.\r\n                           (default: \"turtle\")\r\n  -h,--help                Show this help text\r\n"]
[2.634741, "o", "\u001b[1;32m$\u001b[0m # Overlay only — emit operator-declared entities from a rules.yaml.\r\n"]
[3.24557, "o", "\u001b[1;32m$\u001b[0m tx-graph --rules .../02-alice-bob-ada/rules.yaml | head -20\r\n"]
[3.878808, "o", "@prefix cardano: <https://lambdasistemi.github.io/cardano-knowledge-maps/vocab/cardano#> .\r\n@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .\r\n@prefix :        <https://lambdasistemi.github.io/cardano-tx-tools/fixtures/02-alice-bob-ada#> .\r\n\r\n#\r\n# Operator-declared entities (from rules.yaml).\r\n#\r\n\r\n:alice a cardano:Entity ;\r\n  rdfs:label \"alice\" ;\r\n  cardano:hasIdentifier _:alice_paymentKey ;\r\n  cardano:hasIdentifier _:alice_stakeKey .\r\n\r\n_:alice_paymentKey a cardano:Identifier ;\r\n  cardano:leafType \"PaymentKey\" ;\r\n  cardano:bytesHex \"8bd03209d227956aaf9670751e0aa2057b51c1537a43f155b24fb1c1\" .\r\n\r\n_:alice_stakeKey a cardano:Identifier ;\r\n  cardano:leafType \"StakeKey\" ;\r\n  cardano:bytesHex \"4c7889c658ef4f491a34cf79c35a2e0fe6b0d1b0a856fb9580f2d9c3\" .\r\n"]
[5.889194, "o", "\u001b[1;32m$\u001b[0m # Body only via stdin — Conway tx CBOR piped in, no rules.\r\n"]
[6.497956, "o", "\u001b[1;32m$\u001b[0m cat .../25ba96...cbor.hex | tx-graph --tx - | head -15\r\n"]
[7.119749, "o", "@prefix cardano: <https://lambdasistemi.github.io/cardano-knowledge-maps/vocab/cardano#> .\r\n@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .\r\n@prefix :        <https://lambdasistemi.github.io/cardano-tx-tools/fixtures/tx#> .\r\n\r\n#\r\n# Transaction body.\r\n#\r\n\r\n_:tx a cardano:Transaction ;\r\n  cardano:hasInput _:input1 ;\r\n  cardano:hasOutput _:output1 ;\r\n  cardano:hasOutput _:output2 ;\r\n  cardano:hasOutput _:output3 ;\r\n  cardano:hasOutput _:output4 ;\r\n  cardano:hasOutput _:output5 ;\r\n"]
[9.124071, "o", "\u001b[1;32m$\u001b[0m # Joint graph — rules overlay + body emitted together.\r\n"]
[9.732356, "o", "\u001b[1;32m$\u001b[0m cat .../25ba96...cbor.hex | tx-graph --rules .../rules.yaml --tx - | head -25\r\n"]
[10.358059, "o", "@prefix cardano: <https://lambdasistemi.github.io/cardano-knowledge-maps/vocab/cardano#> .\r\n@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .\r\n@prefix :        <https://lambdasistemi.github.io/cardano-tx-tools/fixtures/tx#> .\r\n\r\n#\r\n# Operator-declared entities (from rules.yaml).\r\n#\r\n\r\n:alice a cardano:Entity ;\r\n  rdfs:label \"alice\" ;\r\n  cardano:hasIdentifier _:alice_paymentKey ;\r\n  cardano:hasIdentifier _:alice_stakeKey .\r\n\r\n_:alice_paymentKey a cardano:Identifier ;\r\n  cardano:leafType \"PaymentKey\" ;\r\n  cardano:bytesHex \"8bd03209d227956aaf9670751e0aa2057b51c1537a43f155b24fb1c1\" .\r\n\r\n_:alice_stakeKey a cardano:Identifier ;\r\n  cardano:leafType \"StakeKey\" ;\r\n  cardano:bytesHex \"4c7889c658ef4f491a34cf79c35a2e0fe6b0d1b0a856fb9580f2d9c3\" .\r\n\r\n:bob a cardano:Entity ;\r\n  rdfs:label \"bob\" ;\r\n  cardano:hasIdentifier _:bob_paymentKey ;\r\n  cardano:hasIdentifier _:bob_stakeKey .\r\n"]
