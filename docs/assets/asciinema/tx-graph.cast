[26.911524, "o", "  cardano:totalCollateral 679298 ;\r\n  cardano:hasCollateralReturn _:collateralReturn1 ;\r\n  cardano:hasRedeemer _:redeemer1 ;\r\n  cardano:hasRedeemer _:redeemer2 ;\r\n  cardano:hasKeyWitness _:keyWitness1 ;\r\n  cardano:hasKeyWitness _:keyWitness2 .\r\n\r\n_:interval1 cardano:intervalEnd 187660799 .\r\n\r\n_:hash_scriptdata_5cc5c166e6c13b9f a cardano:Identifier ;\r\n--\r\n\r\n_:withdrawal1 a cardano:Withdrawal ;\r\n  cardano:withdrawalAccount _:cred_stakescript_a64d1b9e1aeffe54 ;\r\n  cardano:lovelace 0 .\r\n\r\n#\r\n# Collateral 1\r\n#\r\n\r\n_:collateral1 a cardano:Input ;\r\n--\r\n  cardano:hasData _:redeemerData1 ;\r\n  cardano:hasExUnits _:exUnits1 .\r\n\r\n_:redeemerData1 a cardano:Datum ;\r\n  cardano:hasHash _:hash_datum_26b69ac09e67195e ;\r\n  cardano:hasRawBytes \"d87c9fa140a1401b000000124dbcfd03ff\" .\r\n\r\n_:hash_datum_26b69ac09e67195e a cardano:Identifier ;\r\n  cardano:leafType \"DatumHash\" ;\r\n  cardano:bytesHex \"26b69ac09e67195e40a52122fdf60428eed72a7c3b7ca4fb6704ea63eeb8a807\" .\r\n\r\n_:exUnits1 a cardano:ExUnits ;\r\n  cardano:memoryUnits 444067 ;\r\n  cardano:cpuUnits 150371445 .\r\n\r\n_:redeemer2 a cardano:Redeemer ;\r\n"]
