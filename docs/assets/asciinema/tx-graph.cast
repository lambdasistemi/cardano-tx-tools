[27.013747, "o", "/code/cardano-tx-tools-070-body-emit/test/fixtures/rewrite-redesign/04-mint-spend-script-overlap/expected.ttl-  cardano:hasFee 0 ;\r\n/code/cardano-tx-tools-070-body-emit/test/fixtures/rewrite-redesign/04-mint-spend-script-overlap/expected.ttl:  cardano:scriptDataHash _:hash_scriptdata_61a9c0106f3d796e .\r\n/code/cardano-tx-tools-070-body-emit/test/fixtures/rewrite-redesign/04-mint-spend-script-overlap/expected.ttl-\r\n/code/cardano-tx-tools-070-body-emit/test/fixtures/rewrite-redesign/04-mint-spend-script-overlap/expected.ttl-_:hash_scriptdata_61a9c0106f3d796e a cardano:Identifier ;\r\n--\r\n/code/cardano-tx-tools-070-body-emit/test/fixtures/rewrite-redesign/04-mint-spend-script-overlap/expected.ttl-_:mint1 a cardano:Mint ;\r\n/code/cardano-tx-tools-070-body-emit/test/fixtures/rewrite-redesign/04-mint-spend-script-overlap/expected.ttl:  cardano:mintsAsset _:asset1 ;\r\n/code/cardano-tx-tools-070-body-emit/test/fixtures/rewrite-redesign/04-mint-spend-script-overlap/expected.ttl-  cardano:quantity 1000 .\r\n/code/cardano-tx-tools-070-body-emit/test/fixtures/rewrite-redesign/04-mint-spend-script-overlap/expected.ttl-\r\n"]
