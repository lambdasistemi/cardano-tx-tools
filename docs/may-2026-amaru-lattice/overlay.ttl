@prefix amaru: <https://amaru.tech/rdf/> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .

amaru:cag-payee a amaru:BridgeAccount ;
  rdfs:label "cag-payee" .

amaru:antithesis a amaru:Vendor ;
  rdfs:label "Antithesis" ;
  amaru:paidVia amaru:cag-payee .

amaru:castellum a amaru:Vendor ;
  rdfs:label "Castellum" ;
  amaru:paidVia amaru:cag-payee .

