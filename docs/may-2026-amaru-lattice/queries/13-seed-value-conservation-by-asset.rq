PREFIX cardano: <https://lambdasistemi.github.io/cardano-knowledge-maps/vocab/cardano#>
PREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX xsd:     <http://www.w3.org/2001/XMLSchema#>

# Proof gate: for the seed transactions, every observed asset balances
# exactly across resolved spending inputs and outputs. Lovelace includes
# fees on the output side.
#
# A non-zero gap means either the graph is missing an input/output edge,
# a parent output did not resolve, or mint/burn semantics need to be
# included for this transaction set.
SELECT ?assetId ?totalInputQty ?totalOutputQty ?gap
WHERE {
  {
    SELECT ?rawAssetId
           (SUM(?inputQty) AS ?rawInputQty)
           (SUM(?outputQty) AS ?rawOutputQty)
           ((SUM(?inputQty) - SUM(?outputQty)) AS ?rawGap)
    WHERE {
      {
        ?seed cardano:hasLatticeRole "seed" ;
              cardano:hasInput ?input .
        ?input cardano:fromTxOutRef ?ref .
        ?ref cardano:hasTxId/cardano:bytesHex ?parentTxId ;
             cardano:hasIndex ?ix .
        ?parent cardano:hasTxId/cardano:bytesHex ?parentTxId ;
                cardano:hasOutput ?parentOut .
        ?parentOut cardano:hasIndex ?ix ;
                   cardano:lovelace ?inputQty .
        BIND ("lovelace" AS ?rawAssetId)
        BIND (0 AS ?outputQty)
      }
      UNION
      {
        ?seed cardano:hasLatticeRole "seed" ;
              cardano:hasOutput/cardano:lovelace ?outputQty .
        BIND ("lovelace" AS ?rawAssetId)
        BIND (0 AS ?inputQty)
      }
      UNION
      {
        ?seed cardano:hasLatticeRole "seed" ;
              cardano:hasFee ?outputQty .
        BIND ("lovelace" AS ?rawAssetId)
        BIND (0 AS ?inputQty)
      }
      UNION
      {
        ?seed cardano:hasLatticeRole "seed" ;
              cardano:hasInput ?input .
        ?input cardano:fromTxOutRef ?ref .
        ?ref cardano:hasTxId/cardano:bytesHex ?parentTxId ;
             cardano:hasIndex ?ix .
        ?parent cardano:hasTxId/cardano:bytesHex ?parentTxId ;
                cardano:hasOutput ?parentOut .
        ?parentOut cardano:hasIndex ?ix ;
                   cardano:hasAssetValue/rdf:rest*/rdf:first ?asset .
        ?asset cardano:hasIdentifier/cardano:bytesHex ?rawAssetId ;
               cardano:quantity ?inputQty .
        BIND (0 AS ?outputQty)
      }
      UNION
      {
        ?seed cardano:hasLatticeRole "seed" ;
              cardano:hasOutput ?out .
        ?out cardano:hasAssetValue/rdf:rest*/rdf:first ?asset .
        ?asset cardano:hasIdentifier/cardano:bytesHex ?rawAssetId ;
               cardano:quantity ?outputQty .
        BIND (0 AS ?inputQty)
      }
    }
    GROUP BY ?rawAssetId
  }

  BIND ("c48cbb3d5e57ed56e276bc45f99ab39abe94e6cd7ac39fb402da47ad0014df105553444d" AS ?usdmAssetId)
  BIND (IF(?rawAssetId = "lovelace", "ada", IF(?rawAssetId = ?usdmAssetId, "usdm", ?rawAssetId)) AS ?assetId)
  BIND (IF(?rawAssetId = "lovelace" || ?rawAssetId = ?usdmAssetId, xsd:decimal(?rawInputQty) / 1000000, ?rawInputQty) AS ?totalInputQty)
  BIND (IF(?rawAssetId = "lovelace" || ?rawAssetId = ?usdmAssetId, xsd:decimal(?rawOutputQty) / 1000000, ?rawOutputQty) AS ?totalOutputQty)
  BIND (IF(?rawAssetId = "lovelace" || ?rawAssetId = ?usdmAssetId, xsd:decimal(?rawGap) / 1000000, ?rawGap) AS ?gap)
}
ORDER BY ?assetId
