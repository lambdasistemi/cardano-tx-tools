PREFIX cardano: <https://lambdasistemi.github.io/cardano-knowledge-maps/vocab/cardano#>
PREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:    <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd:     <http://www.w3.org/2001/XMLSchema#>

# Average exchange rate for the SundaeSwap V3 swaps that paid USDM into the
# network_compliance treasury.
#
# Query 19 lists the individual swap rows. This query uses the same graph
# proof but aggregates those rows into the answer a user normally asks for:
# how many swaps happened, how much ADA was sold through the orders, how much
# USDM came back, and what average exchange rate the graph implies.
#
# Two averages are reported:
#
# - weightedUsdmPerAdaPpm is the economically meaningful rate for the whole
#   batch: total USDM received / total ADA locked in the consumed orders.
# - simpleMeanUsdmPerAdaPpm is the unweighted mean of the 51 per-producer
#   realized rates. It is useful as a distribution summary, but small swaps and
#   large swaps count equally there.
#
# Rates are parts-per-million USDM per ADA:
#   256810 means 0.256810 USDM / ADA.
SELECT (COUNT(?swapTxId) AS ?swapTxs)
       (SUM(?orderInputCount) AS ?orderInputs)
       (SUM(?orderLovelace) AS ?totalOrderLovelace)
       (SUM(?receivedUsdm) AS ?totalReceivedUsdm)
       (xsd:integer(ROUND((xsd:decimal(SUM(?receivedUsdm)) * 1000000) / xsd:decimal(SUM(?orderLovelace)))) AS ?weightedUsdmPerAdaPpm)
       (AVG(?realizedUsdmPerAdaPpm) AS ?simpleMeanUsdmPerAdaPpm)
       (MIN(?realizedUsdmPerAdaPpm) AS ?minUsdmPerAdaPpm)
       (MAX(?realizedUsdmPerAdaPpm) AS ?maxUsdmPerAdaPpm)
WHERE {
  {
    # Build one proven swap row per producer transaction. The producer must
    # both consume SundaeSwap V3 order UTxOs and emit USDM to
    # network_compliance. This is the same structural payer proof used by
    # Query 21.
    SELECT ?swapTxId ?orderInputCount ?orderLovelace ?receivedUsdm
           (xsd:integer(ROUND((xsd:decimal(?receivedUsdm) * 1000000) / xsd:decimal(?orderLovelace))) AS ?realizedUsdmPerAdaPpm)
    WHERE {
      {
        # Input side: identify the producer txs by consumed Sundae V3 orders.
        SELECT ?swapTx ?swapTxId
               (COUNT(?orderRef) AS ?orderInputCount)
               (SUM(?oneOrderLovelace) AS ?orderLovelace)
        WHERE {
          {
            SELECT DISTINCT ?orderScriptHash
            WHERE {
              # Script hash comes from rules.yaml, not a pasted constant.
              ?orderScript rdfs:label "sundae.swap.v3.order" ;
                           cardano:hasIdentifier/cardano:bytesHex ?orderScriptHash .
            }
          }

          ?swapTx cardano:hasTxId/cardano:bytesHex ?swapTxId ;
                  cardano:hasInput ?in .
          ?in cardano:fromTxOutRef ?ref .
          ?ref cardano:hasTxId/cardano:bytesHex ?orderTxId ;
               cardano:hasIndex ?orderIx .
          ?orderTx cardano:hasTxId/cardano:bytesHex ?orderTxId ;
                   cardano:hasOutput ?orderOut .
          ?orderOut cardano:hasIndex ?orderIx ;
                    cardano:atAddress/cardano:hasPaymentCredential/cardano:hasIdentifier/cardano:bytesHex
                      ?orderScriptHash ;
                    cardano:lovelace ?oneOrderLovelace .

          BIND(CONCAT(?orderTxId, "#", STR(?orderIx)) AS ?orderRef)
        }
        GROUP BY ?swapTx ?swapTxId
      }

      {
        # Output side: sum USDM returned by the same producer txs to the
        # network_compliance treasury.
        SELECT ?swapTx (SUM(?qty) AS ?receivedUsdm)
        WHERE {
          # Full USDM asset id, not ticker text.
          VALUES ?usdmAssetId {
            "c48cbb3d5e57ed56e276bc45f99ab39abe94e6cd7ac39fb402da47ad0014df105553444d"
          }

          ?networkCompliance rdfs:label "amaru-treasury.network_compliance" ;
                             cardano:bech32 ?networkComplianceBech32 .

          ?swapTx cardano:hasOutput ?out .
          ?out cardano:atAddress/cardano:bech32 ?networkComplianceBech32 ;
               cardano:hasAssetValue/rdf:rest*/rdf:first ?asset .
          ?asset cardano:hasIdentifier/cardano:bytesHex ?usdmAssetId ;
                 cardano:quantity ?qty .
        }
        GROUP BY ?swapTx
      }
    }
  }
}
