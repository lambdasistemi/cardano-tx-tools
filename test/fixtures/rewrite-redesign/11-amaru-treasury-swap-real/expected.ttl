_:refInput1 a cardano:Input ;
  cardano:fromTxOutRef _:refInputTxOutRef1 .

_:refInputTxOutRef1 a cardano:TxOutRef ;
  cardano:hasTxId _:hash_txid_0000000000000000 ;
  cardano:hasIndex 0 .

