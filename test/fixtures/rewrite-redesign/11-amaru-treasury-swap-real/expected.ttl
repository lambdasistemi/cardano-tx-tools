#
# Output 1
#

_:output1 a cardano:Output ;
  cardano:atAddress _:cred_paymentkey_0000000000000000Addr ;
  cardano:lovelace 39306821250 ;
  cardano:hasAssetValue _:outputMultiAsset1 .

_:cred_assetclass_c48cbb3d5e57ed56 a cardano:Identifier ;
  cardano:leafType "AssetClass" ;
  cardano:bytesHex "c48cbb3d5e57ed56e276bc45f99ab39abe94e6cd7ac39fb402da47ad5553444d" .

_:outputMultiAsset1 rdf:first _:assetEntry_output1_1 ;
