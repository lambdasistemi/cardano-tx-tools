#
# Operator-declared entities (from rules.yaml).
#

:amaru_treasury_network_compliance a cardano:Entity ;
  rdfs:label "amaru-treasury.network_compliance" ;
  cardano:hasIdentifier _:amaru_treasury_network_compliance_paymentScript ;
  cardano:hasIdentifier _:amaru_treasury_network_compliance_stakeScript .

_:amaru_treasury_network_compliance_paymentScript a cardano:Identifier ;
  cardano:leafType "PaymentScript" ;
  cardano:bytesHex "32201dc1e82708364c6c42a53f89f675314bb9ad5da2734aa10baa0d" .

_:amaru_treasury_network_compliance_stakeScript a cardano:Identifier ;
  cardano:leafType "StakeScript" ;
  cardano:bytesHex "32201dc1e82708364c6c42a53f89f675314bb9ad5da2734aa10baa0d" .

:amaru_swap_order a cardano:Entity ;
  rdfs:label "amaru.swap-order" ;
  cardano:hasIdentifier _:amaru_swap_order_paymentScript ;
  cardano:hasIdentifier _:amaru_treasury_network_compliance_stakeScript .

_:amaru_swap_order_paymentScript a cardano:Identifier ;
