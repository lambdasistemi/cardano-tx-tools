  cardano:bytesHex "fa6a58bbe2d0ff05534431c8e2f0ef2cbdc1602a8456e4b13c8f3077" .

:amaru_swap_v2 a cardano:Entity ;
  rdfs:label "amaru.swap.v2" ;
