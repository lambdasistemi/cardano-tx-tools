:amaru_network_wallet a cardano:Entity ;
  rdfs:label "amaru.network-wallet" ;
  cardano:hasIdentifier _:amaru_network_wallet_paymentKey ;
  cardano:hasIdentifier _:amaru_network_wallet_stakeKey .

_:amaru_network_wallet_paymentKey a cardano:Identifier ;
  cardano:leafType "PaymentKey" ;
  cardano:bytesHex "dea7197ac235d73e7f7b1a249bace6a833722415d88e91dec5d2626d" .

_:amaru_network_wallet_stakeKey a cardano:Identifier ;
  cardano:leafType "StakeKey" ;
  cardano:bytesHex "bc1597ad71c55d2d009a9274b3831ded155118dd769f5376decc1369" .

:usdm a cardano:Entity ;
  rdfs:label "usdm" ;
  cardano:hasIdentifier _:usdm_assetClass .

_:usdm_assetClass a cardano:Identifier ;
  cardano:leafType "AssetClass" ;
  cardano:bytesHex "c48cbb3d5e57ed56e276bc45f99ab39abe94e6cd7ac39fb402da47ad5553444d" .

