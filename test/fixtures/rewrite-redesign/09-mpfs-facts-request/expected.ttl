@prefix cardano: <https://lambdasistemi.github.io/cardano-knowledge-maps/vocab/cardano#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix :        <https://lambdasistemi.github.io/cardano-tx-tools/fixtures/09-mpfs-facts-request#> .

#
# Operator-declared entities (from rules.yaml).
#

:mpfs_oracle a cardano:Entity ;
  rdfs:label "mpfs.oracle" ;
  cardano:hasIdentifier _:mpfs_oracle_paymentScript ;
  cardano:hasIdentifier _:mpfs_oracle_stakeKey .

_:mpfs_oracle_paymentScript a cardano:Identifier ;
  cardano:leafType "PaymentScript" ;
  cardano:bytesHex "ab8aae6afd329c1a07118695a8f6c1f97259cba5e3d1c44505fcb45f" .

_:mpfs_oracle_stakeKey a cardano:Identifier ;
  cardano:leafType "StakeKey" ;
  cardano:bytesHex "5d6741807180e3aa1d8c5e30a2d92a3eea4dcf52f7d4e89bcd06c91d" .

:mpfs_oracle_script a cardano:Entity ;
  rdfs:label "mpfs.oracle.script" ;
  cardano:hasIdentifier _:mpfs_oracle_script_paymentScript .

_:mpfs_oracle_script_paymentScript a cardano:Identifier ;
  cardano:leafType "PaymentScript" ;
  cardano:bytesHex "aa11bb22cc33dd44ee55ff6677889900112233445566778899aabbcc" .

:operator a cardano:Entity ;
  rdfs:label "operator" ;
  cardano:hasIdentifier _:operator_paymentKey ;
  cardano:hasIdentifier _:operator_stakeKey .

_:operator_paymentKey a cardano:Identifier ;
  cardano:leafType "PaymentKey" ;
  cardano:bytesHex "8bd03209d227956aaf9670751e0aa2057b51c1537a43f155b24fb1c1" .

_:operator_stakeKey a cardano:Identifier ;
  cardano:leafType "StakeKey" ;
  cardano:bytesHex "4c7889c658ef4f491a34cf79c35a2e0fe6b0d1b0a856fb9580f2d9c3" .

#
# Transaction body.
#

_:tx a cardano:Transaction ;
  cardano:hasInput _:input1 ;
  cardano:hasOutput _:output1 ;
  cardano:hasOutput _:output2 ;
  cardano:hasOutput _:output3 ;
  cardano:hasOutput _:output4 ;
  cardano:hasOutput _:output5 ;
  cardano:hasOutput _:output6 ;
  cardano:hasOutput _:output7 ;
  cardano:hasOutput _:output8 ;
  cardano:hasOutput _:output9 ;
  cardano:hasOutput _:output10 ;
  cardano:hasOutput _:output11 ;
  cardano:hasFee 0 .

#
# Input 1
#

_:input1 a cardano:Input .

#
# Output 1
#

_:output1 a cardano:Output ;
  cardano:atAddress _:cred_paymentkey_0000000000000000Addr .

#
# Output 2
#

_:output2 a cardano:Output ;
  cardano:atAddress _:cred_paymentkey_0000000000000000Addr .

#
# Output 3
#

_:output3 a cardano:Output ;
  cardano:atAddress _:cred_paymentkey_0000000000000000Addr .

#
# Output 4
#

_:output4 a cardano:Output ;
  cardano:atAddress _:cred_paymentkey_0000000000000000Addr .

#
# Output 5
#

_:output5 a cardano:Output ;
  cardano:atAddress _:cred_paymentkey_0000000000000000Addr .

#
# Output 6
#

_:output6 a cardano:Output ;
  cardano:atAddress _:cred_paymentkey_0000000000000000Addr .

#
# Output 7
#

_:output7 a cardano:Output ;
  cardano:atAddress _:cred_paymentkey_0000000000000000Addr .

#
# Output 8
#

_:output8 a cardano:Output ;
  cardano:atAddress _:cred_paymentkey_0000000000000000Addr .

#
# Output 9
#

_:output9 a cardano:Output ;
  cardano:atAddress _:cred_paymentkey_0000000000000000Addr .

#
# Output 10
#

_:output10 a cardano:Output ;
  cardano:atAddress _:cred_paymentkey_0000000000000000Addr .

#
# Output 11
#

_:output11 a cardano:Output ;
  cardano:atAddress _:cred_paymentkey_0000000000000000Addr .

#
# Address decompositions — payment + stake credential per leaf.
#

_:cred_paymentkey_0000000000000000Addr a cardano:Address ;
  cardano:bech32 "addr_test1vqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqd9tg5t" ;
  cardano:hasPaymentCredential _:cred_paymentkey_0000000000000000CredPayment .

_:cred_paymentkey_0000000000000000CredPayment a cardano:PaymentCredential ;
  cardano:hasIdentifier _:cred_paymentkey_0000000000000000 .
